# Engineering Photo Map - local development environment example
# Copy this file to .env and adjust values for your machine.
# Never commit .env to GitHub.

POSTGRES_DB=photo_map
POSTGRES_USER=photo_user
POSTGRES_PASSWORD=change_this_password

REDIS_URL=redis://redis:6379/0

API_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379

HOST_DATA_DIR=./data

DATA_DIR=/data
ORIGINALS_DIR=/data/originals
UPLOADS_DIR=/data/uploads
THUMBNAILS_DIR=/data/thumbnails
PREVIEWS_DIR=/data/previews
EXPORTS_DIR=/data/exports
TEMP_DIR=/data/temp
LOG_DIR=/data/logs
REPORTS_DIR=/data/reports
BACKUPS_DIR=/data/backups

PUBLIC_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

MAX_UPLOAD_MB=50
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,heic,webp,tif,tiff

DB_STARTUP_RETRY_SECONDS=0
DB_STARTUP_RETRY_INTERVAL=3

MAX_UPLOAD_FILES=999
VITE_MAX_UPLOAD_FILES=999
VITE_UPLOAD_CONCURRENCY=3
