# ============================================================
# 工程照片地图管理系统 - Portainer 测试堆栈公开示例
#
# 用途：
# - 给 photo-map-test 测试堆栈作为公开示例。
# - 可以提交 GitHub。
# - 不包含真实域名、真实公网端口、真实密码、真实内网 IP。
# ============================================================

# 堆栈名称：会用于 Docker 网络名，例如 photo-map-test_default。
COMPOSE_PROJECT_NAME=photo-map-test

# 应用镜像版本：测试环境建议使用具体版本号，验证通过后再推广为 stable。
IMAGE_TAG=v0.4.7-public-initial

# 群晖宿主机上的测试数据目录。
# 测试环境必须和正式环境分开，避免误操作影响正式数据。
HOST_DATA_DIR=/volume1/docker/photo-map-test/data

# PostgreSQL/PostGIS 数据库配置。
POSTGRES_DB=photo_map
POSTGRES_USER=photo_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# 群晖宿主机端口映射。
# FRONTEND_PORT 是群晖宿主机上的前端访问端口，frontend 容器内部端口固定为 5173。
# API_PORT 是群晖宿主机上的后端 API 访问端口，api 容器内部端口固定为 8000。
# 测试端口应和正式堆栈不同，避免端口冲突。
# 测试堆栈建议 FRONTEND_PORT=35173、API_PORT=29000。
FRONTEND_PORT=35173
API_PORT=29000

# 外部访问地址示例。
# 公开示例只使用 example.com；真实域名和真实公网端口请写在本地 .local.env 中。
PUBLIC_BASE_URL=https://phototest.example.com
API_BASE_URL=https://api-test.example.com
VITE_API_BASE_URL=https://api-test.example.com
CORS_ORIGINS=https://phototest.example.com

# 允许访问的 Host。
VITE_ALLOWED_HOSTS=phototest.example.com,api-test.example.com,localhost,127.0.0.1
ALLOWED_HOSTS=phototest.example.com,api-test.example.com,localhost,127.0.0.1

# 上传限制。
MAX_UPLOAD_MB=50
MAX_UPLOAD_FILES=999
VITE_MAX_UPLOAD_FILES=999
VITE_UPLOAD_CONCURRENCY=2

# 媒体 URL 和内部路径前缀。
MEDIA_URL_PREFIX=/media
MEDIA_PREFIX=/media

# 数据库启动等待参数。
DB_STARTUP_RETRY_SECONDS=0
DB_STARTUP_RETRY_INTERVAL=3

# 固定 Docker 网络地址。
# 如果 Docker 提示 network overlaps，说明网段冲突，需要换一个未被占用的网段。
DOCKER_NETWORK_SUBNET=10.77.47.0/24
DOCKER_NETWORK_GATEWAY=10.77.47.1
