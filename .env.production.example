# Engineering Photo Map - production environment example
# Copy this file to .env on the deployment host and change all sensitive values.
# Never commit .env, real photos, database files, logs, reports, or backups.

POSTGRES_DB=photo_map
POSTGRES_USER=photo_user
POSTGRES_PASSWORD=change_this_password

REDIS_URL=redis://redis:6379/0

API_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379

# Local simulation: HOST_DATA_DIR=./data
# Synology example: HOST_DATA_DIR=/volume1/docker/engineering-photo-map/data
# VPS example: HOST_DATA_DIR=/opt/engineering-photo-map/data
# You can change this path to any persistent directory on your host.
HOST_DATA_DIR=./data

DATA_DIR=/data
ORIGINALS_DIR=/data/originals
UPLOADS_DIR=/data/uploads
THUMBNAILS_DIR=/data/thumbnails
PREVIEWS_DIR=/data/previews
EXPORTS_DIR=/data/exports
TEMP_DIR=/data/temp
LOG_DIR=/data/logs
REPORTS_DIR=/data/reports
BACKUPS_DIR=/data/backups

PUBLIC_BASE_URL=https://photos.example.com
API_BASE_URL=https://api.photos.example.com
VITE_API_BASE_URL=https://api.photos.example.com
CORS_ORIGINS=https://photos.example.com,http://localhost:5173,http://127.0.0.1:5173
VITE_ALLOWED_HOSTS=photos.example.com,api.photos.example.com

MAX_UPLOAD_MB=50
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,heic,webp,tif,tiff

DB_STARTUP_RETRY_SECONDS=0
DB_STARTUP_RETRY_INTERVAL=3

MAX_UPLOAD_FILES=999
VITE_MAX_UPLOAD_FILES=999
VITE_UPLOAD_CONCURRENCY=3
