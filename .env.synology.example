# Engineering Photo Map - Synology Portainer environment example
# Copy this file to .env in your Portainer Stack or deployment directory.
# Replace the sample domain, LAN IP, ports, and password before production use.

POSTGRES_DB=photo_map
POSTGRES_USER=photo_user
POSTGRES_PASSWORD=change_this_password

REDIS_URL=redis://redis:6379/0

# Host ports exposed by the Synology NAS. These are examples only.
FRONTEND_PORT=25173
API_PORT=18000

# Example Synology persistent data directory. You may change it to any path.
HOST_DATA_DIR=/volume1/docker/photo-map-v2/data

DATA_DIR=/data
ORIGINALS_DIR=/data/originals
UPLOADS_DIR=/data/uploads
THUMBNAILS_DIR=/data/thumbnails
PREVIEWS_DIR=/data/previews
EXPORTS_DIR=/data/exports
TEMP_DIR=/data/temp
LOG_DIR=/data/logs
REPORTS_DIR=/data/reports
BACKUPS_DIR=/data/backups

PUBLIC_HTTPS_PORT=8443
PUBLIC_BASE_URL=https://photos.example.com:${PUBLIC_HTTPS_PORT}
API_BASE_URL=https://api.photos.example.com:${PUBLIC_HTTPS_PORT}
VITE_API_BASE_URL=https://api.photos.example.com:${PUBLIC_HTTPS_PORT}

CORS_ORIGINS=https://photos.example.com:${PUBLIC_HTTPS_PORT},http://192.168.1.100:25173,http://localhost:5173,http://127.0.0.1:5173
VITE_ALLOWED_HOSTS=photos.example.com,api.photos.example.com,192.168.1.100

DB_STARTUP_RETRY_SECONDS=0
DB_STARTUP_RETRY_INTERVAL=3

MAX_UPLOAD_MB=50
MAX_UPLOAD_FILES=999
VITE_MAX_UPLOAD_FILES=999
VITE_UPLOAD_CONCURRENCY=2

MEDIA_URL_PREFIX=/media
MEDIA_PREFIX=/media