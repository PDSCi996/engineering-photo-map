# ============================================================
# 工程照片地图管理系统 .gitignore
#
# 原则：
# 代码、脚本、文档、示例配置可以提交 GitHub；
# 本地环境、真实照片、日志、检查报告、数据库数据不要提交。
# ============================================================


# ============================================================
# 1. 本地私密配置
# ============================================================

.env
.env.*
!.env.example
!.env.*.example


# ============================================================
# 2. Python 虚拟环境 / 缓存 / 检查缓存
# ============================================================

.venv/
venv/
env/
ENV/

__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage/
htmlcov/

*.egg-info/
.eggs/
.tox/
.nox/
.pytype/


# ============================================================
# 3. Node / 前端依赖与构建产物
# ============================================================

node_modules/
frontend/node_modules/

dist/
build/
frontend/dist/
frontend/build/

.vite/
frontend/.vite/


# ============================================================
# 4. 本地运行数据 / 上传照片 / 数据库持久化数据
# ============================================================

data/
backend/data/
worker/data/

postgres/
redis/

uploads/
backend/uploads/
worker/uploads/

media/
backend/media/
worker/media/

originals/
thumbnails/
previews/
exports/
backups/

output/
outputs/


# ============================================================
# 5. 开发检查日志 / 检查报告 / 临时扫描结果
# ============================================================

logs/
reports/
_scan_for_github/

00-根目录清单.txt
01-项目目录结构_排除大目录.txt
02-数据和临时目录存在情况.txt
03-Git当前状态.txt
04-Git已跟踪文件清单.txt
05-项目内数据和临时目录存在情况.txt


# ============================================================
# 6. 日志和临时文件
# ============================================================

*.log
*.tmp
*.temp
*.bak
*.old
*.orig


# ============================================================
# 7. 数据库文件
# ============================================================

*.db
*.sqlite
*.sqlite3
*.gpkg


# ============================================================
# 8. 图片和视频，防止误传真实照片
#
# 注意：
# 如果以后 frontend/public 里需要放 logo、PWA 图标等，
# 可以单独用 !frontend/public/xxx.png 放行。
# ============================================================

*.jpg
*.jpeg
*.png
*.heic
*.webp
*.tif
*.tiff
*.mp4
*.mov
*.avi


# ============================================================
# 9. 打包文件
# ============================================================

*.zip
*.rar
*.7z
*.tar
*.gz


# ============================================================
# 10. 系统文件
# ============================================================

Thumbs.db
.DS_Store
desktop.ini


# ============================================================
# 11. 编辑器文件
# ============================================================

.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

.idea/


# ============================================================
# 12. 项目导出成果 / QGIS 临时资料包
# ============================================================

*_QGIS资料包*/
*_QGIS资料包_*.zip
*_点位导出_*.csv
*_点位导出_*.geojson
*_QGIS样式_*.qml
*_QGIS使用说明_*.txt


# ============================================================
# 13. 环境示例文件放行
# ============================================================

!.env.example
!.env.*.example
